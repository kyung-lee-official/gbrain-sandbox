# Copy to .env at the repo root. Run gbrain commands from this root.

# gbrain knowledge DB (gbrain CLI + embeddings; needs pgvector)
GBRAIN_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/gbrain

# Bun/Prisma app DB — required, separate from gbrain (create DB e.g. gbrain_app)
APP_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/gbrain_app

# Prisma CLI: use `bun run prisma …` / `bun run prisma:generate` from apps/api
# (those scripts pass --env-file=../../.env)

# Chat (DeepSeek) — used by think-mode synthesis in Bun (not gbrain think)
DEEPSEEK_API_KEY=
GBRAIN_CHAT_MODEL=deepseek:deepseek-v4-flash
# SYNTHESIS_MODEL=deepseek-chat
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Think-mode page hydrate (required for POST /query mode think)
HYDRATE_SCORE_RATIO=0.65
HYDRATE_MAX_PAGES=5
HYDRATE_MAX_CHARS_PER_PAGE=8000
HYDRATE_MAX_TOTAL_CHARS=24000

# Embeddings (Ollama) — shared-source sync/embed
GBRAIN_EMBEDDING_MODEL=ollama:nomic-embed-text
GBRAIN_EMBEDDING_DIMENSIONS=768

# Bun API → gbrain serve --http (shared knowledge only)
# GBRAIN_MCP_BASE_URL=http://localhost:3131
# PORT=3132

# Next.js (apps/web) → Bun API — put in apps/web/.env.local to override
# NEXT_PUBLIC_API_URL=http://localhost:3132
# API_URL=http://localhost:3132
