# Copy to .env at the repo root — Bun API (+ Prisma). Not for gbrain CLI.

# Bun/Prisma app DB (create DB e.g. gbrain_app)
APP_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/gbrain_app

# Prisma CLI: from apps/api → bun run prisma / prisma:generate
# (scripts pass --env-file=../../.env)

# Chat (DeepSeek) — ask-mode synthesis in Bun (gbrain MCP think is not used)
DEEPSEEK_API_KEY=
# Preferred: deepseek:<model>. If unset (and SYNTHESIS_MODEL unset), Bun uses deepseek-chat
GBRAIN_CHAT_MODEL=deepseek:deepseek-v4-flash
# SYNTHESIS_MODEL=deepseek-chat
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# Ask-mode page hydrate (required for POST /query mode ask)
HYDRATE_SCORE_RATIO=0.65
HYDRATE_MAX_PAGES=5
HYDRATE_MAX_CHARS_PER_PAGE=8000
HYDRATE_MAX_TOTAL_CHARS=24000

# Bun API → gbrain serve --http
GBRAIN_MCP_BASE_URL=http://localhost:3131
# Optional overrides (defaults are {GBRAIN_MCP_BASE_URL}/mcp and …/token)
# GBRAIN_MCP_URL=http://localhost:3131/mcp
# GBRAIN_OAUTH_TOKEN_URL=http://localhost:3131/token
# PORT=3132

# Next.js (apps/web) → Bun API — put in apps/web/.env.local to override
# NEXT_PUBLIC_API_URL=http://localhost:3132
# API_URL=http://localhost:3132

# gbrain knowledge DB + embeddings: apps/gbrain/.env (see docs/GBRAIN_SETUP.md)
