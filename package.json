{
  "name": "gbrain-sandbox",
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/bun": "latest",
    "lefthook": "^2.1.10",
    "turbo": "^2.5.4"
  },
  "packageManager": "bun@1.3.12",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@gbrain-sandbox/api",
    "dev:web": "turbo run dev --filter=@gbrain-sandbox/web",
    "seed": "bun --env-file=.env run --filter @gbrain-sandbox/api seed",
    "check-types": "turbo run check-types && bunx tsc --noEmit -p scripts/tsconfig.json",
    "inject:gbrain-demos": "bun run scripts/inject-gbrain-demos.ts",
    "gbrain:sync": "bun run scripts/run-gbrain.ts sync --source shared-source --repo ./shared-source --full --no-pull",
    "gbrain:serve": "bun run scripts/run-gbrain.ts serve --http --port 3131",
    "gbrain:embed": "bun run scripts/run-gbrain.ts embed --stale"
  },
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ]
}
