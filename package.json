{
  "name": "gbrain-sandbox",
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "lefthook": "^2.1.10",
    "turbo": "^2.5.4"
  },
  "packageManager": "bun@1.3.12",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@gbrain-sandbox/api",
    "dev:web": "turbo run dev --filter=@gbrain-sandbox/web",
    "setup:gbrain": "bun --env-file=.env run --filter @gbrain-sandbox/api setup:gbrain",
    "check-types": "turbo run check-types"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
