{
  "name": "gbrain-sandbox",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@gbrain-sandbox/api",
    "dev:web": "turbo run dev --filter=@gbrain-sandbox/web",
    "setup:gbrain": "bun --env-file=.env run --filter @gbrain-sandbox/api setup:gbrain",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "packageManager": "bun@1.3.12",
  "dependencies": {
    "biome": "^0.3.3"
  }
}
